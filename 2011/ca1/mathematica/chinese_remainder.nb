 "\:5165\:529b\:ff1a\:30d9\:30af\:30c8\:30eb \
a=(a_1,...,a_r)\:3092\:7b2c\:ff11\:884c\:306b\:3001\n\t\:4e92\:3044\:306b\
\:7d20\:306a\:6574\:6570\:3092\:6210\:5206\:3068\:3059\:308b\:30d9\:30af\:30c8\
\:30ebm=(m_1,...,m_r)\:3092\:7b2c\:ff12\:884c\:306b\n\t\:6301\:30642\[Times]r\
\:884c\:5217A=",
 Cell[BoxData[
  TagBox[
   RowBox[{"(", "\[NoBreak]", GridBox[{
      {
       RowBox[{"a_", "1"}], "...", "a_r"},
      {
       RowBox[{"m_", "1"}], "...", "m_r"}
     },
     GridBoxAlignment->{
      "Columns" -> {{Center}}, "ColumnsIndexed" -> {}, "Rows" -> {{Baseline}},
        "RowsIndexed" -> {}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.7]}, 
         Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
