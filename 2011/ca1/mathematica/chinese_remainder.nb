          Offset[0.4]}, 
         Offset[0.2]}, "RowsIndexed" -> {}}], "\[NoBreak]", ")"}],
   Function[BoxForm`e$, 
    MatrixForm[BoxForm`e$]]]],
  CellChangeTimes->{3.517227120865275*^9}],
 "\n\:51fa\:529b\:ff1a\:5404i\:306b\:5bfe\:3057, CRA \[Congruent] a_i (mod \
m_i)\:3092\:6e80\:8db3\:3059\:308b\:6574\:6570CRA \:3068\:7a4d m_1\[Times]\
\[Ellipsis]\[Times]m_r\n\
------------------------------------------------------------------------------\
-----------\nSet a = a_1\nSet m = m_1\nIf r=1 Then\n\tCRA=a mod m\nElse\n\t\
For (i=1, i<r, i++) Do\n\tSet t=m^{-1} (a_{i+1}-a) mod m_{i+1}\n\tSet a=a+tm\n\
\tSet m=m(m_{i+1})\n\tEnd For\n\tCRA=a mod m\nEnd If\nReturn (CRA, m)\n\
------------------------------------------------------------------------------\
------------"
}], "Text",
